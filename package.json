{
  "name": "workforce-planner",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,magenta \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "next dev",
    "dev:server": "npm run dev --prefix server",
